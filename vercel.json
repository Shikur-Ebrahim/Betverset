{
  "crons": [
    {
      "path": "/api/cron/bootstrap",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/settle",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/purge",
      "schedule": "0 2 * * *"
    }
  ]
}
