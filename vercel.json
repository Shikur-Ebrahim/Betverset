{
  "crons": [
    {
      "path": "/api/cron/bootstrap",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/settle",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/purge",
      "schedule": "0 2 * * *"
    }
  ]
}
